# ─── Simzzy eSIM Chatbot — Environment Variables ───────────────────────────
# Copy this file to .env and fill in the values before running.

# Server
PORT=3001
NODE_ENV=development

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://simzzy.com

# PostgreSQL (for future persistence layer)
DATABASE_URL=postgresql://user:password@localhost:5432/simzzy_chatbot

# Session TTL in minutes
SESSION_TTL_MINUTES=30
